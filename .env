# Shared non-secret defaults. Checked into git.
# Local overrides and secrets go in .env.local (gitignored).

# Clerk publishable key (safe to expose — it's public)
# Set in .env.local: PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# API base URL for frontend → worker requests
PUBLIC_API_URL=https://api.savecraft.gg

# Canonical MCP server URL shown in connect UI
PUBLIC_MCP_URL=https://mcp.savecraft.gg

# App URL (my.savecraft.gg in production)
PUBLIC_APP_URL=https://my.savecraft.gg

# Install URL for daemon install command
PUBLIC_INSTALL_URL=https://install.savecraft.gg

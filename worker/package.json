{
  "name": "savecraft-worker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "test": "vitest run --reporter=basic",
    "test:shard": "node scripts/test-sharded.mjs",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "fmt": "prettier --write 'src/**/*.ts' 'test/**/*.ts'",
    "fmt:check": "prettier --check 'src/**/*.ts' 'test/**/*.ts'",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.0.0",
    "@cloudflare/workers-oauth-provider": "^0.2.4"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.0",
    "@cloudflare/workers-types": "^4.20250214.0",
    "@eslint/js": "^10.0.1",
    "@vitest/eslint-plugin": "^1.6.9",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-sonarjs": "^4.0.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "~3.0.0",
    "wrangler": "^4.0.0"
  }
}

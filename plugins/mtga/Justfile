build: build-parser

build-parser:
    GOOS=wasip1 GOARCH=wasm go build -o parser.wasm ./parser

test:
    go test -v ./...

# Download Scryfall Oracle Cards and generate Go data files
fetch-scryfall:
    go run ./tools/scryfall-fetch

# Download 17Lands public datasets and generate draft ratings data
fetch-17lands:
    go run ./tools/17lands-fetch

# Download all external data
fetch-all: fetch-scryfall fetch-17lands

{
  "id": 2655,
  "name": "Emberdawn",
  "description": "Emberdawn settled in the gardens of Windrunner Spire after seeking a place to raise her young. Highly territorial, she guards her nest with a searing ferocity.",
  "sections": [
    {
      "title": "Overview",
      "body_text": "Emberdawn lights the winds aflame as she protects her nest. [Burning Gale] pushes players and lights [Ignited Embers], creating [Flaming Twisters] that sweep across the garden.",
      "spell": null,
      "sections": [
        {
          "title": "Damage Dealers",
          "body_text": "$bullet;[Flaming Updraft] leaves behind a [Ignited Embers] upon expiration.\r\n\r\n$bullet;[Burning Gale] pushes players and causes [Ignited Embers] to create [Flaming Twisters].",
          "spell": null,
          "sections": null
        },
        {
          "title": "Healer",
          "body_text": "$bullet;[Flaming Updraft] inflicts significant damage to afflicted players.\r\n\r\n$bullet;[Burning Gale] pushes players and causes [Ignited Embers] to create [Flaming Twisters].",
          "spell": null,
          "sections": null
        },
        {
          "title": "Tank",
          "body_text": "$bullet;Emberdawn's [Searing Beak] inflicts heavy Physical damage followed by significant Fire damage over time.\r\n\r\n$bullet;[Burning Gale] pushes players and causes [Ignited Embers] to create [Flaming Twisters].",
          "spell": null,
          "sections": null
        }
      ]
    },

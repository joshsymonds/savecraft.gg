<?xml version="1.0" encoding="UTF-8"?>
<!--
  Savecraft MSI installer definition (WiX v4).

  Build: wix build -d Version=1.0.0 \
           -d DaemonPath=../../dist/savecraft-daemon-windows-amd64.exe \
           -d TrayPath=../../dist/savecraft-tray-windows-amd64.exe \
           -o savecraft.msi savecraft.wxs

  Per-user install to %LOCALAPPDATA%\Savecraft\. No admin required.
  Launches daemon on MSI completion via Task Scheduler (escapes Job Object).
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">
  <Package
    Name="Savecraft"
    Manufacturer="Savecraft"
    Version="$(var.Version)"
    UpgradeCode="abfd37bd-ee90-4422-8423-2eccd3326a30"
    Scope="perUser"
    Compressed="yes">

    <!-- Allow upgrades, prevent downgrades -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of Savecraft is already installed." />

    <!-- Close running processes before install/upgrade/uninstall.
         Tray has a message loop so WM_CLOSE works; daemon is headless so skip
         CloseMessage and go straight to TerminateProcess (exit code 0). -->
    <util:CloseApplication Id="CloseDaemon" Target="savecraftd.exe" RebootPrompt="no" CloseMessage="no" EndSessionMessage="no" TerminateProcess="0" Timeout="5" />
    <util:CloseApplication Id="CloseTray" Target="savecraft-tray.exe" RebootPrompt="no" CloseMessage="yes" TerminateProcess="0" />

    <MediaTemplate EmbedCab="yes" />



    <Feature Id="Main" Title="Savecraft" Level="1">
      <ComponentRef Id="DaemonExe" />
      <ComponentRef Id="TrayExe" />
      <ComponentRef Id="DaemonStartupKey" />
      <ComponentRef Id="TrayStartupKey" />
    </Feature>

    <!-- Launch daemon after first install via Task Scheduler.

         WHY NOT CreateProcess-based approaches (Type 18, ShellExecuteEx)?
         The MSI's calling context (Add/Remove Programs, SCCM, etc.) may place
         child processes in a Job Object with JOB_OBJECT_LIMIT_KILL_ON_JOB_CLOSE.
         Every child — including asyncNoWait and ShellExecuteEx targets — dies
         when the installer exits. ShellExecuteEx does NOT delegate to explorer;
         it calls CreateProcess internally and inherits the caller's Job Object.

         WHY Task Scheduler WORKS:
         The Task Scheduler service (svchost.exe) creates the process independently,
         outside any Job Object. Pattern: create a one-time task, run it immediately,
         delete the task definition. The running process survives task deletion.
         Works for both interactive and silent (/qn) installs. -->
    <SetProperty Id="CreateLaunchTask" Before="CreateLaunchTask" Sequence="execute"
        Value="&quot;[SystemFolder]schtasks.exe&quot; /create /tn &quot;Savecraft_Launch&quot; /tr &quot;\&quot;[INSTALLFOLDER]savecraftd.exe\&quot; setup&quot; /sc once /st 00:00 /f" />
    <CustomAction Id="CreateLaunchTask"
                  BinaryRef="Wix4UtilCA_$(sys.BUILDARCHSHORT)"
                  DllEntry="WixQuietExec"
                  Execute="deferred"
                  Return="ignore"
                  Impersonate="yes" />

    <SetProperty Id="RunLaunchTask" Before="RunLaunchTask" Sequence="execute"
        Value="&quot;[SystemFolder]schtasks.exe&quot; /run /tn &quot;Savecraft_Launch&quot;" />
    <CustomAction Id="RunLaunchTask"
                  BinaryRef="Wix4UtilCA_$(sys.BUILDARCHSHORT)"
                  DllEntry="WixQuietExec"
                  Execute="deferred"
                  Return="ignore"
                  Impersonate="yes" />

    <SetProperty Id="DeleteLaunchTask" Before="DeleteLaunchTask" Sequence="execute"
        Value="&quot;[SystemFolder]schtasks.exe&quot; /delete /tn &quot;Savecraft_Launch&quot; /f" />
    <CustomAction Id="DeleteLaunchTask"
                  BinaryRef="Wix4UtilCA_$(sys.BUILDARCHSHORT)"
                  DllEntry="WixQuietExec"
                  Execute="deferred"
                  Return="ignore"
                  Impersonate="yes" />

    <InstallExecuteSequence>
      <Custom Action="CreateLaunchTask" Before="InstallFinalize" Condition="NOT REMOVE" />
      <Custom Action="RunLaunchTask" After="CreateLaunchTask" Condition="NOT REMOVE" />
      <Custom Action="DeleteLaunchTask" After="RunLaunchTask" Condition="NOT REMOVE" />
    </InstallExecuteSequence>
  </Package>

  <!-- Install to %LOCALAPPDATA%\Savecraft\ (per-user, no elevation) -->
  <Fragment>
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="INSTALLFOLDER" Name="Savecraft" />
    </StandardDirectory>
  </Fragment>

  <!-- Daemon and tray binaries -->
  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="DaemonExe">
        <File Id="savecraftd.exe" Source="$(var.DaemonPath)" Name="savecraftd.exe" KeyPath="yes" />
        <RemoveFolder Id="RemoveInstallFolder" On="uninstall" />
      </Component>
      <Component Id="TrayExe">
        <File Id="savecraft_tray.exe" Source="$(var.TrayPath)" Name="savecraft-tray.exe" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <!-- Start daemon on login via HKCU Run key -->
  <Fragment>
    <Component Id="DaemonStartupKey" Directory="INSTALLFOLDER">
      <RegistryValue
        Root="HKCU"
        Key="Software\Microsoft\Windows\CurrentVersion\Run"
        Name="Savecraft Daemon"
        Type="string"
        Value="&quot;[INSTALLFOLDER]savecraftd.exe&quot; run"
        KeyPath="yes" />
    </Component>
  </Fragment>

  <!-- Start tray on login via HKCU Run key -->
  <Fragment>
    <Component Id="TrayStartupKey" Directory="INSTALLFOLDER">
      <RegistryValue
        Root="HKCU"
        Key="Software\Microsoft\Windows\CurrentVersion\Run"
        Name="Savecraft Tray"
        Type="string"
        Value="&quot;[INSTALLFOLDER]savecraft-tray.exe&quot;"
        KeyPath="yes" />
    </Component>
  </Fragment>
</Wix>

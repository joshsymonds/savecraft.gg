<?xml version="1.0" encoding="UTF-8"?>
<!--
  Savecraft MSI installer definition (WiX v4).

  Build: wix build -d Version=1.0.0 \
           -d DaemonPath=../../dist/savecraft-daemon-windows-amd64.exe \
           -d TrayPath=../../dist/savecraft-tray-windows-amd64.exe \
           -o savecraft.msi savecraft.wxs

  Per-user install to %LOCALAPPDATA%\Savecraft\. No admin required.
  Launches tray on MSI completion for first-run pairing flow.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package
    Name="Savecraft"
    Manufacturer="Savecraft"
    Version="$(var.Version)"
    UpgradeCode="abfd37bd-ee90-4422-8423-2eccd3326a30"
    Scope="perUser"
    Compressed="yes">

    <!-- Allow upgrades, prevent downgrades -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of Savecraft is already installed." />

    <!-- Close running processes before install/upgrade/uninstall.
         Tray has a message loop so WM_CLOSE works; daemon is headless so skip
         CloseMessage and go straight to TerminateProcess (exit code 0). -->
    <util:CloseApplication Id="CloseDaemon" Target="savecraftd.exe" RebootPrompt="no" CloseMessage="no" EndSessionMessage="no" TerminateProcess="0" Timeout="5" />
    <util:CloseApplication Id="CloseTray" Target="savecraft-tray.exe" RebootPrompt="no" CloseMessage="yes" TerminateProcess="0" />

    <MediaTemplate EmbedCab="yes" />

    <!-- Show install progress and completion UI -->
    <ui:WixUI Id="WixUI_Minimal" />

    <Feature Id="Main" Title="Savecraft" Level="1">
      <ComponentRef Id="DaemonExe" />
      <ComponentRef Id="TrayExe" />
      <ComponentRef Id="DaemonStartupKey" />
      <ComponentRef Id="TrayStartupKey" />
    </Feature>

    <!-- Launch daemon and tray after install.
         Type 18 custom actions: run installed files directly. asyncNoWait so
         MSI doesn't block. Daemon first, then tray for first-run pairing. -->
    <CustomAction Id="LaunchDaemon" FileRef="savecraftd.exe" ExeCommand="" Return="asyncNoWait" />
    <CustomAction Id="LaunchTray" FileRef="savecraft_tray.exe" ExeCommand="" Return="asyncNoWait" />
    <InstallExecuteSequence>
      <Custom Action="LaunchDaemon" After="InstallFinalize" Condition="NOT Installed" />
      <Custom Action="LaunchTray" After="LaunchDaemon" Condition="NOT Installed" />
    </InstallExecuteSequence>
  </Package>

  <!-- Install to %LOCALAPPDATA%\Savecraft\ (per-user, no elevation) -->
  <Fragment>
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="INSTALLFOLDER" Name="Savecraft" />
    </StandardDirectory>
  </Fragment>

  <!-- Daemon and tray binaries -->
  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="DaemonExe">
        <File Id="savecraftd.exe" Source="$(var.DaemonPath)" Name="savecraftd.exe" KeyPath="yes" />
        <RemoveFolder Id="RemoveInstallFolder" On="uninstall" />
      </Component>
      <Component Id="TrayExe">
        <File Id="savecraft_tray.exe" Source="$(var.TrayPath)" Name="savecraft-tray.exe" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <!-- Start daemon on login via HKCU Run key -->
  <Fragment>
    <Component Id="DaemonStartupKey" Directory="INSTALLFOLDER">
      <RegistryValue
        Root="HKCU"
        Key="Software\Microsoft\Windows\CurrentVersion\Run"
        Name="Savecraft Daemon"
        Type="string"
        Value="[INSTALLFOLDER]savecraftd.exe"
        KeyPath="yes" />
    </Component>
  </Fragment>

  <!-- Start tray on login via HKCU Run key -->
  <Fragment>
    <Component Id="TrayStartupKey" Directory="INSTALLFOLDER">
      <RegistryValue
        Root="HKCU"
        Key="Software\Microsoft\Windows\CurrentVersion\Run"
        Name="Savecraft Tray"
        Type="string"
        Value="[INSTALLFOLDER]savecraft-tray.exe"
        KeyPath="yes" />
    </Component>
  </Fragment>
</Wix>
